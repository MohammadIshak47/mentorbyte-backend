# Copy this file to .env and fill in real values before running locally.
# .env is in .gitignore and is NEVER pushed to GitHub — it stays on your
# machine only. This .env.example file (with no real secrets) is the one
# that gets committed, so anyone cloning the repo knows what variables
# they need to set.

# Django
SECRET_KEY=your-very-long-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_SSL_REQUIRE=False

# PostgreSQL (local dev example — update user/password to match your setup)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mentorbyte

# CORS — your Netlify URL goes here in production
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# Frontend URL (used for building links)
FRONTEND_URL=http://localhost:5173
